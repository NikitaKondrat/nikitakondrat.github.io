1 \u0438\u044e\u043d\u044f 2007 \u0433\u043e\u0434\u0430 \u0432 \u0433\u043e\u0440\u043e\u0434\u0435 \u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433 \u0438 \u0436\u0438\u0432\u0451\u0442 \u0442\u0430\u043c \u0434\u043e \u0441\u0438\u0445 \u043f\u043e\u0440 \u041e\u043a\u043e\u043d\u0447\u0438\u043b \u0448\u043a\u043e\u043b\u0443 558 \u0412\u044b\u0431\u043e\u0440\u0433\u0441\u043a\u043e\u0433\u043e \u0440\u0430\u0439\u043e\u043d\u0430 \u043f\u043e\u0441\u043b\u0435 11 \u043a\u043b\u0430\u0441\u0441\u0430(2025 \u0433\u043e\u0434) \u0421\u0435\u0439\u0447\u0430\u0441 \u0443\u0447\u0438\u0442\u0441\u044f \u0432 \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0418\u0422\u041c\u041e (\u0432 \u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435) \u043d\u0430 \u043d\u0430\u043f\u0440\u0432\u043b\u0435\u043d\u0438\u044f \"\u041d\u0435\u0439\u0440\u043e\u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\" \u043d\u0430 \u0442\u0440\u0435\u043a\u0435 \"\u0418\u043d\u0436\u0435\u043d\u0435\u0440\u0438\u044f \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0438\u043d\u0442\u0435\u043b\u043b\u0435\u043a\u0442\u0430\", \u0432 \u0433\u0440\u0443\u043f\u043f\u0435 P3123 \u043d\u0430 1 \u043a\u0443\u0440\u0441\u0435","title":"About author"},{"location":"about/#_1","text":"\u0420\u043e\u0434\u0438\u043b\u0441\u044f 1 \u0438\u044e\u043d\u044f 2007 \u0433\u043e\u0434\u0430 \u0432 \u0433\u043e\u0440\u043e\u0434\u0435 \u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433 \u0438 \u0436\u0438\u0432\u0451\u0442 \u0442\u0430\u043c \u0434\u043e \u0441\u0438\u0445 \u043f\u043e\u0440 \u041e\u043a\u043e\u043d\u0447\u0438\u043b \u0448\u043a\u043e\u043b\u0443 558 \u0412\u044b\u0431\u043e\u0440\u0433\u0441\u043a\u043e\